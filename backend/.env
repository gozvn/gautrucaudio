# Application Configuration
APP_ENV=development
APP_NAME=Novel App
APP_FRONTEND_URL=http://localhost:4200
APP_SSL_ACTIVE=false
APP_SSL_PORT=443
APP_SSL_KEY_PATH=
APP_SSL_CERT_PATH=
APP_TEMPLATE=default
PUBLIC_TOKEN=123123

# Application Modules
APP_MODULES=
APP_MODULES_ECO_DATA_HUB=

# Google Configuration
GOOGLE_RECAPTCHA_ACTIVE=false
GOOGLE_RECAPTCHA_URL=https://www.google.com/recaptcha/api/siteverify
GOOGLE_RECAPTCHA_V3_SECRET_KEY=
GOOGLE_EMAIL_EXTENSIONS=

# Notification Configuration
NOTIFICATION_ENABLE=false
NOTIFICATION_CHAT_ID=
NOTIFICATION_TOKEN=

# MySQL Database Configuration
MYSQL_HOST=nuc
MYSQL_PORT=3306
MYSQL_USER=goz_admin
MYSQL_PASSWORD=admin
MYSQL_DATABASE=gautrucaudio

# MySQL Eco Data Hub Configuration
MYSQL_ECO_DATA_HUB_HOST=localhost
MYSQL_ECO_DATA_HUB_PORT=3306
MYSQL_ECO_DATA_HUB_USER=root
MYSQL_ECO_DATA_HUB_PASSWORD=
MYSQL_ECO_DATA_HUB_DATABASE=

# Redis Configuration
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PORT=6379
REDIS_CACHE_AUTH=
REDIS_CACHE_DB=0

# JWT Configuration
JWT_SECRET=34d7d913-7c70-4e3b-bd3e-34204c5c87a5
JWT_ALGORITHM=HS256
JWT_TTL=2592000
JWT_SECRET_REFRESH=your_jwt_refresh_secret_key_here
JWT_ALGORITHM_REFRESH=HS256

# Authentication Configuration
AUTH_BASIC_USERNAME=admin
AUTH_BASIC_PASSWORD=password

# Encryption Configuration
ENCRYPT_ALGORITHM=aes-256-ctr
ENCRYPT_SECRET_KEY=your_encryption_secret_key_here

# API Keys Configuration
AUTH_DATA_API_KEY_NAME=x-data-api-key
AUTH_WEBHOOK_API_KEY_VALUE=your_webhook_api_key_here
AUTH_WEBHOOK_API_KEY_NAME=x-webhook-api-key

# Email Configuration
EMAIL_TYPE=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=Novel App
EMAIL_CC=
EMAIL_BCC=

# Web RSA Configuration
WEB_RSA_IS_ACTIVE=false
WEB_RSA_PRIVATE_KEY=
WEB_RSA_PUBLIC_KEY=

# Google OAuth Configuration
GOOGLE_APP_CLIENT_ID=
GOOGLE_APP_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Request Logging
ENABLE_LOG_REQUEST=false